# Liora 环境变量配置

# Flask配置
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_PORT=5000

# ============================================
# 大模型API配置（支持OpenAI兼容格式）
# ============================================

# MiniMax 配置（推荐）
# 文档: https://platform.minimaxi.com/document/ChatCompletion%20v2?key=66701d281d57f38758d581b4
LLM_API_KEY=sk-cp-bj_s-m2TPi4FRRBlJbELLky7UtOryazr3uIDOjYPd4ftVvzda953SZkG0u8_iO8uz24MD1VPlsvXWmQdK4brHAmkQzubpvak4tvghDpbGpTHoGFbq3wVM1w
LLM_BASE_URL=https://api.minimaxi.chat/v1
LLM_MODEL_NAME=minimax-text-01

# 备用：其他服务商配置（取消注释使用）

# OpenAI 官方
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o

# 智谱AI (GLM-4V)
# LLM_API_KEY=your-zhipu-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL_NAME=glm-4v

# 百度文心一言
# LLM_API_KEY=your-baidu-key
# LLM_BASE_URL=https://qianfan.baidubce.com/v2
# LLM_MODEL_NAME=ernie-4.0

# ============================================
# 语音转文本配置（Whisper）
# ============================================

# MiniMax 语音（支持中文，推荐）
WHISPER_API_KEY=${LLM_API_KEY}
WHISPER_BASE_URL=https://api.minimaxi.chat/v1
WHISPER_MODEL_NAME=whisper-1

# 或使用 OpenAI Whisper
# WHISPER_API_KEY=sk-your-openai-key
# WHISPER_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL_NAME=whisper-1
